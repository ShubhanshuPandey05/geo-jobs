# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=geojobs
DB_USER=geojobs
DB_PASSWORD=geojobs_secret_123

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Meilisearch
MEILI_HOST=http://localhost:7700
MEILI_MASTER_KEY=geojobs_meili_master_key_123

# Server
PORT=3001
NODE_ENV=development

# Admin API (used by scraper scripts to call the server)
ADMIN_API_TOKEN=your_random_admin_token_here
API_BASE_URL=http://localhost:3001

# Mapbox (Get your token at https://account.mapbox.com/)
VITE_MAPBOX_TOKEN=your_mapbox_token_here

# API URL for frontend
VITE_API_URL=http://localhost:3001/api

# Scraper
SCRAPER_CONCURRENCY=5
MAX_BROWSERS=3
DIRECT_MODE=false
LOG_LEVEL=info

# Ollama AI Validation
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b
AI_CONFIDENCE_THRESHOLD=0.6
OLLAMA_TIMEOUT=120000

# Career URL Enrichment (Ollama-first)
OLLAMA_DISCOVERY_MODEL=qwen:7b
CAREER_URL_CONFIDENCE_THRESHOLD=0.75
CAREER_DISCOVERY_TIMEOUT_MS=30000
